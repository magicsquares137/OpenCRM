# =============================================================================
# Arkitekt OpenCRM - Environment Configuration Template
# =============================================================================
# 
# This is a template file for environment variables required by the application.
# Copy this file to .env and fill in your actual values.
# 
# IMPORTANT SECURITY NOTES:
# - Never commit the actual .env file to version control
# - Keep your credentials secure and rotate them regularly
# - Use different credentials for development and production
# - Restrict access to .env file (chmod 600 .env on Unix systems)
# 
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Fill in all required values marked with <REQUIRED>
# 3. Adjust optional values as needed
# 4. Ensure .env is in .gitignore
# 
# =============================================================================

# =============================================================================
# Meta (Facebook) Lead Ads API Configuration
# =============================================================================
# 
# These credentials are required to fetch lead data from Meta Lead Ads.
# 
# How to obtain:
# 1. Go to https://developers.facebook.com/
# 2. Create or select your app
# 3. Navigate to your Facebook Page settings
# 4. Generate a Page Access Token with 'leads_retrieval' permission
# 5. Get your Page ID from Page Settings or Graph API Explorer
# 
# Documentation:
# https://developers.facebook.com/docs/marketing-api/guides/lead-ads/

# Meta Page ID (Facebook Page ID where the Lead Ad form is located)
# Example: 123456789012345
# Required: Yes
META_PAGE_ID=<REQUIRED>

# Meta Page Access Token (Long-lived access token with leads_retrieval permission)
# Example: EAABwzLixnjYBO...
# Required: Yes
# Security: This is highly sensitive - keep it secure!
META_PAGE_ACCESS_TOKEN=<REQUIRED>

# Meta Form ID (Optional: Specific form ID to fetch leads from)
# Leave empty to fetch from all forms on the page
# Example: 987654321098765
# Required: No
# META_FORM_ID=

# Meta API Version (Optional: Specify API version to use)
# Default: v21.0
# Example: v21.0
META_API_VERSION=v21.0

# =============================================================================
# Microsoft Graph API Configuration (Azure AD / Outlook)
# =============================================================================
# 
# These credentials are required to send emails via Microsoft Graph API.
# 
# How to obtain:
# 1. Go to https://portal.azure.com/
# 2. Navigate to Azure Active Directory > App registrations
# 3. Create a new app registration or select existing
# 4. Copy the Application (client) ID and Directory (tenant) ID
# 5. Create a client secret in Certificates & secrets
# 6. Grant API permissions: Mail.Send, Mail.ReadWrite
# 7. Grant admin consent for the permissions
# 
# Documentation:
# https://docs.microsoft.com/en-us/graph/auth-v2-service

# Microsoft Tenant ID (Azure AD Directory ID)
# Example: a1b2c3d4-e5f6-7890-abcd-ef1234567890
# Required: Yes
MS_TENANT_ID=<REQUIRED>

# Microsoft Client ID (Application ID from Azure App Registration)
# Example: 12345678-1234-1234-1234-123456789012
# Required: Yes
MS_CLIENT_ID=<REQUIRED>

# Microsoft Client Secret (Secret value from Azure App Registration)
# Example: abc123~DEF456.ghi789-JKL012
# Required: Yes
# Security: This is highly sensitive - keep it secure!
MS_CLIENT_SECRET=<REQUIRED>

# Sender Email Address (Email address to send from - must have mailbox access)
# Example: leads@yourdomain.com
# Required: Yes
MS_SENDER_EMAIL=<REQUIRED>

# Recipient Email Address (Email address to send lead notifications to)
# Can be comma-separated for multiple recipients
# Example: sales@yourdomain.com,manager@yourdomain.com
# Required: Yes (if not set, defaults to sender email)
# MS_RECIPIENT_EMAIL=

# Email Subject Template (Optional: Customize email subject line)
# Available placeholders: {name}, {email}, {phone}, {date}
# Default: New Lead: {name}
EMAIL_SUBJECT_TEMPLATE=New Lead: {name}

# =============================================================================
# Booking/Scheduling Configuration
# =============================================================================
# 
# URL for booking appointments or scheduling calls with leads.
# This URL will be included in the email sent to recipients.

# Booking URL (Link to your booking/scheduling page)
# Example: https://calendly.com/your-name/consultation
# Required: Yes
BOOKING_URL=<REQUIRED>

# =============================================================================
# Branding & Identity Configuration
# =============================================================================

# Sender Name (Name shown in email signature and AI-generated emails)
# Example: Jane Smith
# Required: No (emails will use "The Team" if not set)
SENDER_NAME=

# Company Name (Your company/business name)
# Example: Acme Corp
# Required: No (used in email templates and AI-generated emails)
COMPANY_NAME=

# Company Description (Brief description of your business for AI email generation)
# Example: We build custom software solutions for small businesses
# Required: No (helps the AI write more relevant outreach emails)
COMPANY_DESCRIPTION=

# =============================================================================
# AI / LLM Configuration (Optional — for AI email generation)
# =============================================================================
# Supports any OpenAI-compatible API (OpenAI, Ollama, Together, Groq, etc.)
# as well as Anthropic. Set LLM_API_KEY at minimum to enable AI features.

# LLM API Key
# For OpenAI: sk-...
# For Anthropic: sk-ant-...
# Required: No (AI features disabled if not set)
LLM_API_KEY=

# LLM Model (default: gpt-4o)
# Examples: gpt-4o, gpt-4o-mini, claude-sonnet-4-20250514, llama3, etc.
LLM_MODEL=gpt-4o

# LLM Base URL (optional — for self-hosted or alternative providers)
# Examples: http://localhost:11434/v1 (Ollama), https://api.together.xyz/v1
# Leave empty for default OpenAI/Anthropic endpoints
LLM_BASE_URL=

# LLM Provider (auto-detected from API key if not set)
# Options: openai, anthropic
# Default: openai (unless API key starts with sk-ant-)
LLM_PROVIDER=

# =============================================================================
# Mailgun Configuration (Optional — for campaigns)
# =============================================================================

# Mailgun API Key
# Required: No (only needed if sending campaigns via Mailgun)
MAILGUN_API_KEY=

# Mailgun Domain (e.g. mg.yourdomain.com)
MAILGUN_DOMAIN=

# Mailgun Sender Email (e.g. campaigns@mg.yourdomain.com)
MAILGUN_SENDER_EMAIL=

# Mailgun Region (us or eu)
# Default: us
MAILGUN_REGION=us

# =============================================================================
# Webhook Ingestion
# =============================================================================

# Webhook API Key (enables POST /api/webhook/leads endpoint)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Required: No (webhook endpoint disabled if not set)
WEBHOOK_API_KEY=

# =============================================================================
# Application Configuration
# =============================================================================

# Environment Mode
# Options: development, production, staging
# Default: production
ENVIRONMENT=production

# Polling Interval (How often to check for new leads, in seconds)
# Default: 900 (15 minutes)
# Minimum recommended: 300 (5 minutes)
# Example: 900, 1800, 3600
POLL_INTERVAL_SECONDS=900

# Batch Size (Number of leads to fetch per API call)
# Default: 100
# Maximum: 500 (API limit)
BATCH_SIZE=100

# =============================================================================
# Database Configuration
# =============================================================================

# Database Path (SQLite database file location)
# Default: /app/data/leads.db (for Docker)
# Local development: ./data/leads.db
DB_PATH=/app/data/leads.db

# Database Backup Enabled (Automatically backup database)
# Options: true, false
# Default: true
DB_BACKUP_ENABLED=true

# Database Backup Interval (Hours between automatic backups)
# Default: 24
DB_BACKUP_INTERVAL_HOURS=24

# =============================================================================
# Logging Configuration
# =============================================================================

# Log Level (Verbosity of logging output)
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
# Development: DEBUG
# Production: INFO or WARNING
LOG_LEVEL=INFO

# Log File Path (Location of application log file)
# Default: /app/data/pipeline.log (for Docker)
# Local development: ./logs/pipeline.log
LOG_FILE_PATH=/app/data/pipeline.log

# Console Logging Enabled (Output logs to console/stdout)
# Options: true, false
# Default: true
LOG_CONSOLE_ENABLED=true

# Log Format
# Options: json, text
# Default: text
# Production recommended: json (for log aggregation)
LOG_FORMAT=text

# Log Rotation Enabled (Automatically rotate log files)
# Options: true, false
# Default: true
LOG_ROTATION_ENABLED=true

# Log Rotation Max Size (Maximum log file size in MB before rotation)
# Default: 10
LOG_ROTATION_MAX_MB=10

# Log Rotation Backup Count (Number of rotated log files to keep)
# Default: 5
LOG_ROTATION_BACKUP_COUNT=5

# =============================================================================
# Error Handling & Retry Configuration
# =============================================================================

# Maximum Retries (Number of retry attempts for failed API calls)
# Default: 3
MAX_RETRIES=3

# Retry Delay (Initial delay between retries in seconds)
# Default: 5
# Note: Uses exponential backoff (5s, 10s, 20s, etc.)
RETRY_DELAY=5

# Request Timeout (HTTP request timeout in seconds)
# Default: 30
REQUEST_TIMEOUT=30

# =============================================================================
# Email Configuration (Advanced)
# =============================================================================

# Email Template Path (Optional: Custom HTML email template)
# Default: Uses built-in template
# EMAIL_TEMPLATE_PATH=/app/config/email_template.html

# Email Include Attachments (Attach lead data as file)
# Options: true, false
# Default: false
EMAIL_INCLUDE_ATTACHMENTS=false

# Email Format
# Options: html, text, both
# Default: html
EMAIL_FORMAT=html

# Email Priority
# Options: high, normal, low
# Default: normal
EMAIL_PRIORITY=normal

# =============================================================================
# Health Check Configuration
# =============================================================================

# Health Check Enabled (Enable HTTP health check endpoint)
# Options: true, false
# Default: true
HEALTH_CHECK_ENABLED=true

# Health Check Port (Port for health check HTTP server)
# Default: 8080
HEALTH_CHECK_PORT=8080

# Health Check Path (URL path for health check endpoint)
# Default: /health
HEALTH_CHECK_PATH=/health

# =============================================================================
# Security Configuration
# =============================================================================

# Enable SSL Verification (Verify SSL certificates for API calls)
# Options: true, false
# Default: true
# WARNING: Only set to false for testing/development
SSL_VERIFY=true

# Token Encryption Enabled (Encrypt tokens in database)
# Options: true, false
# Default: false
TOKEN_ENCRYPTION_ENABLED=false

# Encryption Key (Required if TOKEN_ENCRYPTION_ENABLED=true)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=

# =============================================================================
# Rate Limiting Configuration
# =============================================================================

# Rate Limit Enabled (Enable rate limiting for API calls)
# Options: true, false
# Default: true
RATE_LIMIT_ENABLED=true

# Rate Limit Requests (Maximum requests per time window)
# Default: 100
RATE_LIMIT_REQUESTS=100

# Rate Limit Window (Time window in seconds)
# Default: 3600 (1 hour)
RATE_LIMIT_WINDOW_SECONDS=3600

# =============================================================================
# Notification Configuration (Optional)
# =============================================================================

# Slack Webhook URL (Optional: Send notifications to Slack)
# Example: https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXX
# SLACK_WEBHOOK_URL=

# Discord Webhook URL (Optional: Send notifications to Discord)
# Example: https://discord.com/api/webhooks/123456789/abcdefghijklmnop
# DISCORD_WEBHOOK_URL=

# Send Notification on Error (Send notifications for errors)
# Options: true, false
# Default: false
SEND_ERROR_NOTIFICATIONS=false

# Send Notification on Success (Send notifications for successful lead processing)
# Options: true, false
# Default: false
SEND_SUCCESS_NOTIFICATIONS=false

# =============================================================================
# Development & Testing Configuration
# =============================================================================

# Dry Run Mode (Test without actually sending emails or writing to database)
# Options: true, false
# Default: false
# DRY_RUN=false

# Mock API Responses (Use mock data instead of real API calls)
# Options: true, false
# Default: false
# MOCK_API_ENABLED=false

# Debug Mode (Enable detailed debug output)
# Options: true, false
# Default: false
# DEBUG=false

# =============================================================================
# Performance Tuning
# =============================================================================

# Connection Pool Size (Maximum concurrent API connections)
# Default: 10
CONNECTION_POOL_SIZE=10

# Cache Enabled (Enable caching for API responses)
# Options: true, false
# Default: true
CACHE_ENABLED=true

# Cache TTL (Cache time-to-live in seconds)
# Default: 300 (5 minutes)
CACHE_TTL_SECONDS=300

# =============================================================================
# Timezone Configuration
# =============================================================================

# Timezone (Timezone for timestamps and scheduling)
# Default: UTC
# Examples: America/New_York, Europe/London, Asia/Tokyo
# Use IANA timezone names: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=UTC

# =============================================================================
# Additional Notes
# =============================================================================
# 
# 1. After creating your .env file, validate it:
#    - Ensure all <REQUIRED> fields are filled
#    - Check for typos in variable names
#    - Verify credentials are correct
# 
# 2. Security best practices:
#    - Never share your .env file
#    - Use strong, unique secrets
#    - Rotate credentials regularly
#    - Use environment-specific credentials
#    - Consider using a secrets manager (AWS Secrets Manager, Azure Key Vault, etc.)
# 
# 3. Testing your configuration:
#    - Run with LOG_LEVEL=DEBUG first
#    - Test Meta API: curl "https://graph.facebook.com/v21.0/me?access_token=YOUR_TOKEN"
#    - Test Azure credentials: Use Azure Portal or Graph Explorer
# 
# 4. Docker deployment:
#    - Mount .env file: docker run --env-file .env ...
#    - Or use docker-compose.yml which automatically loads .env
# 
# 5. Monitoring:
#    - Check logs regularly: tail -f /app/data/pipeline.log
#    - Monitor health endpoint: curl http://localhost:9010/health
#    - Set up alerts for errors
# 
# =============================================================================
