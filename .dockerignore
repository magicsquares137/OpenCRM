.pytest_tmp/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/
.cache/
nosetests.xml
test-results/
junit/
*.test
*.out

# =============================================================================
# Documentation
# =============================================================================
# Exclude documentation files (can be kept if needed for reference)
README.md
CHANGELOG.md
CONTRIBUTING.md
LICENSE
*.md
docs/
doc/
*.rst
*.txt
!requirements.txt
!requirements-*.txt

# =============================================================================
# Docker Files
# =============================================================================
# Exclude Docker-related files (except Dockerfile itself)
docker-compose.yml
docker-compose.*.yml
.dockerignore
Dockerfile.dev
Dockerfile.test
Dockerfile.old

