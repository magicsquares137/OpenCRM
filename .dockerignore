# =============================================================================
# Arkitekt OpenCRM - Docker Ignore File
# =============================================================================
# 
# This file specifies which files and directories should be excluded from the
# Docker build context. Excluding unnecessary files:
# - Reduces build context size
# - Speeds up build time
# - Prevents sensitive data from being copied into images
# - Reduces final image size
# 
# Syntax:
# - Lines starting with # are comments
# - Use * as wildcard
# - Use ** to match multiple directory levels
# - Use ! to negate (include) a pattern
# 
# =============================================================================

# =============================================================================
# Environment and Configuration Files
# =============================================================================
# Exclude sensitive environment files - these should be mounted at runtime
.env
.env.*
!.env.example
*.env
env.local
.envrc

# =============================================================================
# Python Cache and Compiled Files
# =============================================================================
# Exclude Python bytecode and cache directories
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# Compiled C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# =============================================================================
# Virtual Environments
# =============================================================================
# Exclude virtual environment directories
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/
virtualenv/

# =============================================================================
# Version Control
# =============================================================================
# Exclude Git repository and related files
.git/
.gitignore
.gitattributes
.gitmodules
.git-credentials
*.orig
*.rej

