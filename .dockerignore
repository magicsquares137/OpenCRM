*.pem
*.key
*.cert
*.crt
*.csr
*.p12
*.pfx
.secret
.password
credentials.json
service-account.json
*.key.json

# =============================================================================
# Temporary Files
# =============================================================================
# Exclude temporary files and directories
tmp/
temp/
.tmp/
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig
.cache/
cache/

# =============================================================================
# Media and Large Files
# =============================================================================
# Exclude media files that shouldn't be in the image
*.mp4
*.avi
*.mov
*.mp3
*.wav
*.zip
*.tar
*.tar.gz
*.rar
*.7z
*.iso
*.dmg

# =============================================================================
# Monitoring and Profiling
# =============================================================================
# Exclude monitoring and profiling data
*.prof
*.profile
.profiling/
monitoring/

# =============================================================================
# Backup Files
# =============================================================================
# Exclude backup files
backups/
backup/
*.backup
*-backup
*.bak
*-old
*.save

# =============================================================================
# Sample and Example Files
# =============================================================================
# Exclude example files (keep .env.example as it's needed for reference)
examples/
sample/
samples/
demo/
demos/

# =============================================================================
# Scripts and Tools
# =============================================================================
# Exclude development scripts that aren't needed in production
scripts/dev/
scripts/local/
scripts/test/
tools/
utilities/
setup.sh
install.sh
dev.sh

# =============================================================================
# Custom Exclusions
# =============================================================================
# Add project-specific exclusions below

# Exclude local development database
local.db
dev.db
test.db

# Exclude local configuration overrides
config.local.json
config.dev.json
config.override.json

# Exclude prototype and experimental code
prototypes/
experiments/
sandbox/
scratch/

# Exclude design and assets not needed in production
design/
assets/source/
*.psd
*.ai
*.sketch
*.fig

# Exclude research and notes
research/
notes/
*.notes
*.todo
TODO.md
NOTES.md

# =============================================================================
# Important Notes
# =============================================================================
# 
# 1. Security:
#    - Never include .env or credentials in Docker images
#    - Use Docker secrets or environment variables at runtime
#    - Sensitive files should be mounted as volumes, not copied
# 
# 2. Performance:
#    - Smaller build context = faster builds
#    - Exclude large files and directories you don't need
#    - Use .dockerignore even if files are in .gitignore
# 
# 3. Best Practices:
#    - Keep .dockerignore synchronized with .gitignore where applicable
#    - Document project-specific exclusions
#    - Test your .dockerignore: docker build --no-cache .
#    - Check build context size: docker build . 2>&1 | grep "Sending build context"
# 
# 4. Debugging:
#    - To see what's being sent to Docker daemon:
#      tar -C . -czf - . | tar -tzv | grep -v "/$"
#    - To check ignored files are actually ignored:
#      docker build --progress=plain --no-cache . 2>&1 | grep COPY
# 
# 5. Maintenance:
#    - Review this file periodically
#    - Update when adding new file types to the project
#    - Consider using glob patterns for entire categories
# 
# =============================================================================
